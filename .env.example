# ==============================================================================
# HYDRONIX PRODUCTION ENVIRONMENT CONFIGURATION
# Optimized for TrueNAS SCALE (Portainer Stack), Traefik / Nginx Proxy Manager,
# and Cloudflare Tunnel integration.
# ==============================================================================

# --- System & Localization ---
TZ=Asia/Kolkata
NODE_ENV=production
LOG_LEVEL=INFO

# --- Application Metadata ---
APP_NAME=Hydronix
FRONTEND_URL=https://hydronix.yourdomain.com
API_URL=https://api.hydronix.yourdomain.com
WS_URL=wss://api.hydronix.yourdomain.com/ws/updates

# --- Feature Flags ---
REGISTRATION_ENABLED=false
PUBLIC_DASHBOARD_ENABLED=true

# --- Authentication Configuration ---
# Generate a secure 32-byte secret using: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_SECURE_32_BYTE_HEX
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d
SUPER_ADMIN_EMAIL=superadmin@hydronix.com
SUPER_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# --- PostgreSQL Configuration ---
POSTGRES_HOST=hydronix-postgres
POSTGRES_PORT=5432
POSTGRES_DB=hydronix_db
POSTGRES_USER=hydronix_admin
POSTGRES_PASSWORD=CHANGE_ME_TO_A_SECURE_DB_PASSWORD
# Connection pool settings
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# --- Redis Configuration ---
REDIS_HOST=hydronix-redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_TO_A_SECURE_REDIS_PASSWORD

# --- MQTT Configuration ---
# Bridge client settings
MQTT_HOST=hydronix-mqtt-bridge
MQTT_PORT=1883
MQTT_USERNAME=hydronix_bridge
MQTT_PASSWORD=CHANGE_ME_TO_A_SECURE_MQTT_PASSWORD
MQTT_TLS=false

# --- MinIO Configuration (S3-Compatible) ---
MINIO_ENDPOINT=hydronix-minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_production_admin
MINIO_SECRET_KEY=CHANGE_ME_TO_A_SECURE_MINIO_SECRET_KEY
MINIO_BUCKET=hydronix-data-bucket

# --- Persistent Storage (Host dataset mappings on TrueNAS SCALE) ---
# Enforce paths pointing directly to mapped dataset pools
REPORTS_STORAGE=/mnt/tank/docker-data/hydronix/reports
UPLOAD_STORAGE=/mnt/tank/docker-data/hydronix/uploads
LOG_STORAGE=/mnt/tank/docker-data/hydronix/logs
BACKUP_STORAGE=/mnt/tank/docker-data/hydronix/backups

# --- Data Retention Policies ---
# Purge raw telemetry sensor_data after N days, maintaining aggregate tables
RETENTION_RAW_DATA_DAYS=90
RETENTION_ALERTS_DAYS=365
RETENTION_BACKUPS_DAYS=30

# --- Water Quality Thresholds (Rule-Based Alerts) ---
QUALITY_SCORE_SAFE_PH_MIN=6.5
QUALITY_SCORE_SAFE_PH_MAX=8.5
QUALITY_SCORE_SAFE_TURBIDITY_MAX=5.0
QUALITY_SCORE_SAFE_TDS_MAX=300.0
QUALITY_SCORE_SAFE_TEMPERATURE_MIN=5.0
QUALITY_SCORE_SAFE_TEMPERATURE_MAX=45.0
QUALITY_SCORE_SAFE_FLOW_RATE_MAX=100.0

# --- Security Headers & CORS ---
CORS_ORIGINS=["https://hydronix.yourdomain.com","https://api.hydronix.yourdomain.com"]
SECURE_HEADERS_ENABLED=true
RATE_LIMIT_PER_DEVICE_MINUTE=60
RATE_LIMIT_PER_IP_HOUR=5000
