# ==============================================================================
# Hydronix Platform Configuration Environment Variables
# ==============================================================================

# --- Application ---
APP_NAME=Hydronix
NODE_ENV=production
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
WS_URL=ws://localhost:8000/ws/updates

# --- Authentication ---
JWT_SECRET=production_secret_key_change_me_immediately
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d
SUPER_ADMIN_EMAIL=superadmin@hydronix.com
SUPER_ADMIN_PASSWORD=change_this_default_superadmin_password

# --- PostgreSQL ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=hydronix_db
POSTGRES_USER=hydronix
POSTGRES_PASSWORD=secure_postgres_password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=secure_redis_password

# --- MQTT ---
MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_USERNAME=hydronix_device_bridge
MQTT_PASSWORD=secure_mqtt_password
MQTT_TLS=false

# --- MinIO ---
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minio_admin_key
MINIO_SECRET_KEY=minio_admin_secret_key
MINIO_BUCKET=hydronix-bucket

# --- Storage Paths (Inside Containers) ---
REPORTS_STORAGE=/storage/hydronix/reports
UPLOAD_STORAGE=/storage/hydronix/uploads
LOG_STORAGE=/storage/hydronix/logs
BACKUP_STORAGE=/storage/hydronix/backups

# --- Monitoring ---
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
LOG_LEVEL=INFO
