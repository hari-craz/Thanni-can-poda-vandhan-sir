{
  "annotations":{
    "list":[]
  },
  "panels":[
    {
      "type":"graph",
      "title":"Prediction Request Count",
      "targets":[{"expr":"rate(ml_requests_total[5m])"}],
      "id":1
    },
    {
      "type":"graph",
      "title":"Prediction Request Latency (p95)",
      "targets":[{"expr":"histogram_quantile(0.95, sum(rate(ml_request_latency_seconds_bucket[5m])) by (le))"}],
      "id":2
    },
    {
      "type":"stat",
      "title":"Feedback Accuracy (1h)",
      "targets":[{"expr":"(increase(ml_feedback_correct[1h]) / (increase(ml_feedback_total[1h]) + 0.0001))"}],
      "id":3
    },
    {
      "type":"graph",
      "title":"Exported Rows (1h)",
      "targets":[{"expr":"increase(ml_exported_rows_total[1h])"}],
      "id":4
    },
    {
      "type":"graph",
      "title":"Backup Success vs Failure (1h)",
      "targets":[{"expr":"increase(ml_backup_success_total[1h])"},{"expr":"increase(ml_backup_failure_total[1h])"}],
      "id":5
    },
    {
      "type":"stat",
      "title":"Last Export Duration (s)",
      "targets":[{"expr":"ml_export_last_duration_seconds"}],
      "id":6
    }
  ],
  "title":"Hydronix ML Service Overview",
  "schemaVersion":16
}
