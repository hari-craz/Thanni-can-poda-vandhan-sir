# ==============================================================================
# HYDRONIX LOCAL TESTING ENVIRONMENT CONFIGURATION
# ==============================================================================

# --- System & Localization ---
TZ=Asia/Kolkata
NODE_ENV=development
LOG_LEVEL=DEBUG

# --- Application Metadata ---
APP_NAME=Hydronix-Local
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:8000
WS_URL=ws://localhost:8000/ws/updates

# --- Feature Flags ---
REGISTRATION_ENABLED=true
PUBLIC_DASHBOARD_ENABLED=true

# --- Authentication Configuration ---
# Simple secrets for local development only
JWT_SECRET=local_testing_secret_key_1234567890
JWT_EXPIRY=24h
REFRESH_TOKEN_EXPIRY=7d
SUPER_ADMIN_EMAIL=admin@localhost.com
SUPER_ADMIN_PASSWORD=admin

# --- PostgreSQL Configuration ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=hydronix_db
POSTGRES_USER=hydronix
POSTGRES_PASSWORD=hydronix_pass
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# --- Redis Configuration ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# --- Security & HTTPS (Disabled for Local Dev) ---
CLOUDFLARE_TUNNEL_ENABLED=false
HTTPS_ONLY=false
FORCE_HTTPS_REDIRECT=false
HMAC_VALIDATION_ENABLED=false

# --- Local Storage Paths ---
# Configured for D:\New folder as requested
REPORTS_STORAGE=D:\New folder\reports
UPLOAD_STORAGE=D:\New folder\uploads
LOG_STORAGE=D:\New folder\logs
BACKUP_STORAGE=D:\New folder\backups

# --- Data Retention Policies ---
RETENTION_RAW_DATA_DAYS=90
RETENTION_ALERTS_DAYS=365
RETENTION_BACKUPS_DAYS=30

# --- Water Quality Thresholds (Rule-Based Alerts) ---
QUALITY_SCORE_SAFE_PH_MIN=6.5
QUALITY_SCORE_SAFE_PH_MAX=8.5
QUALITY_SCORE_SAFE_TURBIDITY_MAX=5.0
QUALITY_SCORE_SAFE_TDS_MAX=300.0
QUALITY_SCORE_SAFE_TEMPERATURE_MIN=5.0
QUALITY_SCORE_SAFE_TEMPERATURE_MAX=45.0
QUALITY_SCORE_SAFE_FLOW_RATE_MAX=100.0

# --- Security Headers & CORS ---
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:10020"]
SECURE_HEADERS_ENABLED=false
RATE_LIMIT_PER_DEVICE_MINUTE=600
RATE_LIMIT_PER_IP_HOUR=50000
